<Window x:Class="VoiceSynthWPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Настройки" 
        WindowStartupLocation="CenterOwner"
        Height="420" Width="520" 
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource PanelsBrush}">
    <Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource PanelsBrush}" MouseLeftButtonDown="TopBar_MouseDown">
                <Grid>
                    <TextBlock Text="Настройки" 
                               Foreground="{StaticResource PrimaryTextBrush}" 
                               FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Style="{StaticResource FlatButtonStyle}" 
                            HorizontalAlignment="Right" 
                            Width="30" Height="30"
                            Click="Cancel_Click">
                        <Path Data="M14.5,13.5 L1.5,0.5 M1.5,13.5 L14.5,0.5" 
                              Stroke="#CCFFFFFF" 
                              StrokeThickness="2" 
                              Stretch="Uniform"
                              Width="12" Height="12"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,8,16,8">
                <StackPanel>

                    <!-- Audio Device -->
                    <TextBlock Text="Аудио-устройство вывода" 
                               Foreground="{StaticResource GrayTextBrush}" 
                               FontSize="11" Margin="0,12,0,4"/>
                    <ComboBox x:Name="DeviceComboBox" 
                              Style="{StaticResource FlatComboBoxStyle}"
                              Margin="0,0,0,0"/>

                    <!-- Voice -->
                    <TextBlock Text="Голос" 
                               Foreground="{StaticResource GrayTextBrush}" 
                               FontSize="11" Margin="0,12,0,4"/>
                    <ComboBox x:Name="VoiceComboBox" 
                              Style="{StaticResource FlatComboBoxStyle}"
                              Margin="0,0,0,0"/>

                    <!-- Speed -->
                    <TextBlock Text="Скорость речи" 
                               Foreground="{StaticResource GrayTextBrush}" 
                               FontSize="11" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SpeedSlider" 
                                Grid.Column="0"
                                Minimum="-10" Maximum="10" 
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SpeedSlider_ValueChanged"
                                Foreground="{StaticResource AdditionalBrush}"
                                Margin="0,4,8,4"/>
                        <TextBlock x:Name="SpeedLabel" 
                                   Grid.Column="1"
                                   Foreground="{StaticResource PrimaryTextBrush}" 
                                   VerticalAlignment="Center"
                                   Text="0"/>
                    </Grid>

                    <!-- Volume -->
                    <TextBlock Text="Громкость" 
                               Foreground="{StaticResource GrayTextBrush}" 
                               FontSize="11" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="VolumeSlider" 
                                Grid.Column="0"
                                Minimum="0" Maximum="100" 
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="VolumeSlider_ValueChanged"
                                Foreground="{StaticResource AdditionalBrush}"
                                Margin="0,4,8,4"/>
                        <TextBlock x:Name="VolumeLabel" 
                                   Grid.Column="1"
                                   Foreground="{StaticResource PrimaryTextBrush}" 
                                   VerticalAlignment="Center"
                                   Text="100"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Grid Grid.Row="2" Margin="16,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="1" Margin="0,8,8,8" Height="32" BorderThickness="1" BorderBrush="{StaticResource AdditionalBrush}" CornerRadius="5">
                    <Button Style="{StaticResource FlatButtonStyle}" 
                            Width="90"
                            Click="Cancel_Click">
                        <TextBlock Text="Отмена" Foreground="{StaticResource GrayTextBrush}"/>
                    </Button>
                </Border>
                <Border Grid.Column="2" Margin="0,8,0,8" Height="32" BorderThickness="1" BorderBrush="DarkRed" CornerRadius="5">
                    <Button Style="{StaticResource FlatButtonStyle}" 
                            Width="90"
                            Click="Save_Click">
                        <TextBlock Text="Сохранить" Foreground="#DC0D00"/>
                    </Button>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
